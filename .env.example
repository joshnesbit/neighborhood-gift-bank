# Neon (Postgres) — DB
# In Vercel: Storage → Create Database → Neon (env var injected automatically).
# Locally: paste the pooled connection string from the Neon dashboard.
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Anthropic (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (server-side only) — for the daily follow-up email digest
RESEND_API_KEY=re_...
REMINDER_EMAIL_FROM=Neighborhood Gift Bank <notifications@relationaltechproject.org>
REMINDER_EMAIL_TO=joshuanesbit@gmail.com

# Public URL used for links inside the reminder emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects /api/cron/send-reminders. Generate with: openssl rand -hex 32
CRON_SECRET=

# Single-user password gate. Leave blank to bypass auth (demo mode).
APP_PASSWORD=
